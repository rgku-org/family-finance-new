{
  "crons": [
    {
      "path": "/api/process-recurring",
      "schedule": "0 9 * * *"
    },
    {
      "path": "/api/weekly-summary",
      "schedule": "0 18 * * 0"
    },
    {
      "path": "/api/inactivity-reminder",
      "schedule": "0 10 * * *"
    }
  ],
  "functions": {
    "src/app/api/**/*": {
      "maxDuration": 60
    }
  },
  "env": {
    "CRON_SECRET": "@cron-secret"
  }
}
